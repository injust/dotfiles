{
    "accessibility.signals.terminalBell": { "sound": "on" },
    "basedpyright.analysis.diagnosticMode": "workspace",
    "editor.cursorBlinking": "smooth",
    "editor.foldingImportsByDefault": true,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.guides.bracketPairs": true, // https://github.com/zed-industries/zed/discussions/31378
    "editor.inlayHints.enabled": "onUnlessPressed",
    "editor.renderFinalNewline": "dimmed",
    "explorer.confirmDragAndDrop": false,
    "explorer.fileNesting.enabled": true,
    "files.autoSave": "afterDelay",
    "files.autoSaveWorkspaceFilesOnly": true,
    "git.autofetch": "all",
    "git.enableCommitSigning": true,
    "git.fetchOnPull": true,
    "git.followTagsWhenSync": true,
    "git.mergeEditor": true,
    "git.pruneOnFetch": true,
    "git.pullBeforeCheckout": true,
    "git.rebaseWhenSync": true,
    "git.terminalGitEditor": true,
    "mypy-type-checker.importStrategy": "fromEnvironment",
    "mypy-type-checker.reportingScope": "workspace",
    "python.REPL.sendToNativeREPL": true,
    "terminal.external.osxExec": "Ghostty.app",
    "terminal.integrated.confirmOnExit": "hasChildProcesses", // https://github.com/zed-industries/zed/discussions/31377
    "terminal.integrated.fontLigatures": true,
    "terminal.integrated.persistentSessionScrollback": 1000,
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.suggest.enabled": true
}
