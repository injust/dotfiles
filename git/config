[advice]
	detachedHead = false
	skippedCherryPicks = false

[alias]
	lol = log --oneline --graph
	lola = "!f() { git lol --all $(git rev-parse --verify --quiet --not refs/spice/data); }; f"
	show-ignored = "!f() { git ls-files -z --others --ignored --directory --exclude-standard \"${GIT_PREFIX:-.}\" | xargs --null --no-run-if-empty eza --classify --icons --hyperlink --treat-dirs-as-files; }; f"

	# difftastic
	difft = -c diff.external=difft diff
	showt = -c diff.external=difft show --ext-diff

	# abbr-git.fish
	am = commit --amend --no-edit
	ame = commit --amend
	ap = add --patch
	br = branch
	brd = branch --delete
	cl = clone
	clb = cloneb
	cloneb = clone --filter=blob:none
	cm = commit
	co = checkout
	cp = cherry-pick
	cpn = cherry-pick --no-commit
	df = diff --patch --stat
	dfc = diffc
	dft = difft
	dftc = difft --cached
	dftu = difft @{upstream}
	dfu = diffu
	diffc = diff --patch --stat --cached
	diffu = diff --patch --stat @{upstream}
	fe = fetch
	gr = grep --break --heading
	lgu = log @{upstream}
	pushf = push --force-with-lease
	rb = rebase
	rba = rebase --abort
	rbc = rebase --continue
	rbe = "!f() { git rebase --edit-todo && git rebase --continue; }; f"
	rbi = rebase --interactive
	rst = reset
	rsth = reset --hard
	sh = show --patch --stat
	sht = showt
	st = status
	sw = switch
	swc = switch --create

[branch]
	autoSetupRebase = always

[checkout]
	workers = 0

[commit]
	gpgSign = true

[core]
	pager = "LESS=\"$LESS --jump-target=1\" LESSSECURE= delta --line-numbers"

[credential]
	helper =

[delta]
	commit-decoration-style = "#6c7086"  # Unbold and remove `box ul`
	file-decoration-style = "#6c7086" box ul  # Add `box ul`
	hunk-header-decoration-style = "#6c7086"  # Remove `box ul`

	# Octicons
	file-added-label = 
	file-copied-label = 
	file-modified-label = 
	file-removed-label = 
	file-renamed-label = 
	hunk-label = 

	max-line-length = 0
	max-syntax-highlighting-length = 0
	navigate = true
	right-arrow = =>
	tabs = 4

[diff]
	algorithm = histogram
	colorMoved = dimmed-zebra
	colorMovedWS = allow-indentation-change
	noPrefix = true
	renames = copies
	submodule = log

[diff "plist"]
	textconv = plutil -convert xml1 -o -

[feature]
	manyFiles = true

[fetch]
	all = true
	parallel = 0
	prune = true
	pruneTags = true
	writeCommitGraph = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	process = git-lfs filter-process
	required = true
	smudge = git-lfs smudge -- %f

[gpg]
	format = ssh

[gpg "ssh"]
	defaultKeyCommand = sh -c 'echo key::$(ssh-add -L | head -n1)'

[grep]
	lineNumber = true

[include]
	path = catppuccin.gitconfig

[init]
	defaultBranch = main

[interactive]
	diffFilter = delta --color-only --line-numbers
	singleKey = true

[log]
	abbrevCommit = true

[merge]
	autoStash = true
	conflictStyle = diff3
	ff = false

[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L

[pager]
	difft = less
	showt = less

[pull]
	ff = only
	rebase = merges

[push]
	autoSetupRemote = true
	# negotiate = true  # Not supported by Codeberg or GitHub
	useForceIfIncludes = true

[rebase]
	autoSquash = true
	autoStash = true
	rebaseMerges = true
	updateRefs = true

[rerere]
	autoUpdate = true
	enabled = true

[safe]
	bareRepository = explicit

[sequence]
	editor = interactive-rebase-tool

[spice "branchCheckout"]
	showUntracked = true
	trackUntracked = true

[stash]
	showIncludeUntracked = true
	showPatch = true

[submodule]
	fetchJobs = 0
	recurse = true

[tag]
	gpgSign = true

[transfer]
	fsckObjects = true

[url "codecommit://"]
	insteadOf = cc:

[url "github.com:"]
	insteadOf = gh:

[url "gist.github.com:"]
	insteadOf = gist:

[user]
	email = injustsu@gmail.com
	name = Justin Su
	useConfigOnly = true
