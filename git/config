[alias]
	br = branch
	co = checkout
	cp = cherry-pick
	df = diff
	dfc = diff --cached
	diffc = diff --cached
	lol = log --decorate --oneline --graph
	lola = log --decorate --all --oneline --graph
	rb = rebase
	rba = rebase --abort
	rbc = rebase --continue
	rbi = rebase --interactive
	sh = show
	st = status
	sw = switch

[commit]
	gpgSign = true

[core]
	fsmonitor = true
	untrackedcache = true

[credential]
	helper = 

[diff]
	colorMoved = dimmed-zebra
	colorMovedWS = allow-indentation-change

[fetch]
	prune = true

[gpg]
	format = ssh

[init]
	defaultBranch = main

[pull]
	rebase = true

[user]
	email = injustsu@gmail.com
	name = Justin Su
	signingKey = ~/.ssh/keys/github-signing.pub
