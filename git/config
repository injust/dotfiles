[alias]
	br = branch
	co = checkout
	cp = cherry-pick
	df = diff
	dfc = diff --cached
	diffc = diff --cached
	lol = log --decorate --oneline --graph
	lola = log --decorate --all --oneline --graph
	rb = rebase
	rba = rebase --abort
	rbc = rebase --continue
	rbi = rebase --interactive
	sh = show
	st = status
	sw = switch

[commit]
	gpgSign = true

[core]
	fsmonitor = true
	# Override `LESS=FRX` default to unbreak mouse scrolling (https://github.com/gwsw/less/issues/445)
	pager = LESS='--quit-if-one-screen --RAW-CONTROL-CHARS' delta
	# Work around macOS rebase error (https://www.git-tower.com/blog/make-git-rebase-safe-on-osx/)
	trustctime = false
	untrackedcache = true

[credential]
	helper = 

[delta]
	features = catppuccin-mocha
	hyperlinks = true
	hyperlinks-file-link-format = "vscode://file/{path}:{line}"
	max-line-length = 0
	navigate = true
	tabs = 4

[diff]
	colorMoved = default

[fetch]
	prune = true

[gpg]
	format = ssh

[include]
	path = catppuccin.gitconfig

[init]
	defaultBranch = main

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictstyle = diff3

[pull]
	rebase = true

[user]
	email = injustsu@gmail.com
	name = Justin Su
	signingKey = ~/.ssh/keys/github-signing.pub
