[alias]
	diffc = diff --cached
	rba = rebase --abort
	rbc = rebase --continue
	rbi = rebase --interactive

[commit]
	gpgSign = true

[core]
	editor = nano

[diff]
	colorMoved = dimmed-zebra
	colorMovedWS = allow-indentation-change

[fetch]
	prune = true

[gpg]
	format = ssh

[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[pull]
	rebase = true

