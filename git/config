[alias]
	br = branch
	co = checkout
	cp = cherry-pick
	df = diff
	dfc = diff --cached
	diffc = diff --cached
	lol = log --decorate --oneline --graph
	lola = log --decorate --all --oneline --graph
	rb = rebase
	rba = rebase --abort
	rbc = rebase --continue
	rbi = rebase --interactive
	sh = show
	st = status
	sw = switch

[commit]
	gpgSign = true

[core]
	fsmonitor = true
	# Override `LESS=FRX` default to unbreak mouse scrolling (https://github.com/gwsw/less/issues/445)
	# Treat Nerd Font characters used in delta labels as printable
	pager = LESS='--quit-if-one-screen --RAW-CONTROL-CHARS' LESSUTFCHARDEF=EBCC:p,F459:p,F4D0:p,F4D2:p,F4D5-F4D6:p delta
	# Work around macOS rebase error (https://www.git-tower.com/blog/make-git-rebase-safe-on-osx/)
	trustctime = false
	untrackedcache = true

[credential]
	helper = 

[delta]
	features = catppuccin-mocha
	file-added-label = 
	file-copied-label = 
	file-modified-label = 
	file-removed-label = 
	file-renamed-label = 
	hunk-label = 
	hyperlinks = true
	hyperlinks-file-link-format = "vscode://file/{path}:{line}"
	max-line-length = 0
	navigate = true
	tabs = 4

[diff]
	colorMoved = default

[fetch]
	prune = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	process = git-lfs filter-process
	required = true
	smudge = git-lfs smudge -- %f

[gpg]
	format = ssh

[include]
	path = catppuccin.gitconfig

[init]
	defaultBranch = main

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictstyle = diff3

[pull]
	rebase = true

[sequence]
	editor = interactive-rebase-tool

[user]
	email = injustsu@gmail.com
	name = Justin Su
	signingKey = ~/.ssh/keys/github-signing.pub
