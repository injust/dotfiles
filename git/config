[advice]
	detachedHead = false
	skippedCherryPicks = false

[alias]
	ad = add
	am = commit --amend --no-edit
	ame = commit --amend
	br = branch
	cl = clone
	cm = commit
	co = checkout
	cp = cherry-pick
	df = diff
	dfc = diffc
	dfu = diffu
	diffc = diff --cached
	diffu = diff @{upstream}
	gr = grep --break --heading
	lg = log
	lgu = log @{upstream}
	lol = log --decorate --oneline --graph
	lola = lol --all
	rb = rebase
	rba = rebase --abort
	rbc = rebase --continue
	rbi = rebase --interactive
	sh = show
	st = status
	sw = switch
	swc = switch --create

	show-ignored = !git clean -d --dry-run -X | sed 's/^Would remove //'

[branch]
	autoSetupRebase = always

[checkout]
	workers = 0

[commit]
	gpgSign = true

[core]
	fsmonitor = true
	# Override `LESS=FRX` default to unbreak mouse scrolling (https://github.com/gwsw/less/issues/445)
	pager = LESS='--quit-if-one-screen --RAW-CONTROL-CHARS' delta --line-numbers
	# Work around macOS rebase error (https://www.git-tower.com/blog/make-git-rebase-safe-on-osx/)
	trustctime = false
	untrackedCache = true

[credential]
	helper = 

[delta]
	features = catppuccin-mocha
	file-added-label = ’ōÉ
	file-copied-label = Ņ»ī
	file-modified-label = ’ōÆ
	file-removed-label = ’ō¢
	file-renamed-label = ’ōĢ
	hunk-label = ’æÖ
	max-line-length = 0
	max-syntax-highlighting-length = 0
	navigate = true
	tabs = 4

	# TODO(https://github.com/dandavison/delta/issues/1837): Remove when delta uses `line-numbers` styles from Catppuccin feature
	line-numbers-left-style = "#6c7086"
	line-numbers-minus-style = bold "#f38ba8"
	line-numbers-plus-style = bold "#a6e3a1"
	line-numbers-right-style = "#6c7086"
	line-numbers-zero-style = "#6c7086"

[diff]
	algorithm = histogram
	colorMoved = default
	mnemonicPrefix = true
	renames = copies

[feature]
	experimental = true
	manyFiles = true

[fetch]
	prune = true
	pruneTags = true
	writeCommitGraph = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	process = git-lfs filter-process
	required = true
	smudge = git-lfs smudge -- %f

[gpg]
	format = ssh

[grep]
	lineNumber = true

[help]
	autoCorrect = immediate

[include]
	path = catppuccin.gitconfig

[init]
	defaultBranch = main

[interactive]
	diffFilter = delta --color-only --line-numbers
	singleKey = true

[log]
	abbrevCommit = true

[merge]
	autoStash = true
	conflictStyle = zdiff3

[pull]
	ff = only
	rebase = merges

[push]
	autoSetupRemote = true
	negotiate = true
	useForceIfIncludes = true

[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true

[rerere]
	autoUpdate = true
	enabled = true

[sequence]
	editor = interactive-rebase-tool

[submodule]
	recurse = true

[tag]
	gpgSign = true

[transfer]
	fsckObjects = true

[url "git@github.com:"]
	insteadOf = gh:

[user]
	email = injustsu@gmail.com
	name = Justin Su
	signingKey = ~/.ssh/keys/github-signing
	useConfigOnly = true
