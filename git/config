[alias]
	diffc = diff --cached
	lol = log --abbrev-commit --graph --decorate --pretty=oneline
	lola = log --abbrev-commit --all --graph --decorate --pretty=oneline
	rba = rebase --abort
	rbc = rebase --continue
	rbi = rebase --interactive

[commit]
	gpgSign = true

[core]
	fsmonitor = true
	untrackedcache = true

[diff]
	colorMoved = dimmed-zebra
	colorMovedWS = allow-indentation-change

[fetch]
	prune = true

[gpg]
	format = ssh

[init]
	defaultBranch = main

[pull]
	rebase = true

[user]
	email = injustsu@gmail.com
	name = Justin Su
	signingKey = ~/.ssh/keys/github-signing.pub
