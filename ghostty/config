font-family = MonaspiceAr Nerd Font Propo

font-feature = calt
font-feature = liga
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss07
font-feature = ss08
font-feature = ss09

adjust-cell-width = -1

theme = catppuccin-mocha

background-opacity = 0.95
background-blur-radius = 20

keybind = super+enter=ignore

# adjust_selection
keybind = shift+end=adjust_selection:end_of_line
keybind = shift+home=adjust_selection:beginning_of_line
keybind = super+shift+left=adjust_selection:beginning_of_line
keybind = super+shift+right=adjust_selection:end_of_line

# Rebind equalize_splits to match default resize_split keybindings
keybind = alt+shift+equal=unbind
keybind = super+ctrl+equal=equalize_splits

# Rebind super+page_up/down to jump_to_prompt to free up super+shift+up/down
keybind = super+page_up=jump_to_prompt:-1
keybind = super+shift+down=unbind
keybind = super+shift+up=unbind
keybind = super+page_down=jump_to_prompt:1

# https://www.gnu.org/software/bash/manual/html_node/Commands-For-Moving.html
# beginning-of-line (C-a)
keybind = super+left=text:\x01
# end-of-line (C-e)
keybind = super+right=text:\x05
# forward-word (M-f)
keybind = alt+right=esc:f
# backward-word (M-b)
keybind = alt+left=esc:b

# https://www.gnu.org/software/bash/manual/html_node/Commands-For-Killing.html
# kill-line (C-k)
keybind = super+delete=text:\x0b
# unix-line-discard (C-u)
keybind = super+backspace=text:\x15
# kill-word (M-d)
keybind = alt+delete=esc:d

window-padding-x = 4
window-padding-y = 4

clipboard-paste-protection = false

quit-after-last-window-closed = true

shell-integration-features = true

# TODO(https://github.com/ghostty-org/ghostty/issues/392): Use non-native fullscreen when it works with tabs
macos-non-native-fullscreen = false

macos-titlebar-style = tabs
