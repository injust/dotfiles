{
    "$schema": "https:\/\/schema.linearmouse.app\/0.10.4",
    "schemes": [
        {
            "buttons": { "universalBackForward": true },
            "if": { "device": { "category": "mouse" } },
            "scrolling": { "reverse": true }
        },
        {
            "if": { "app": "com.colliderli.iina", "device": { "category": "mouse" } },
            "scrolling": {
                "reverse": { "vertical": false } // https://github.com/linearmouse/linearmouse/issues/1153
            }
        }
    ]
}
