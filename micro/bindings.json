{
    "\u001b[1;9A": "CursorStart", // cmd-up
    "\u001b[1;9B": "CursorEnd", // cmd-down
    "\u001b[1;10C": "SelectToEndOfLine", // cmd-shift-right
    "\u001b[1;10D": "SelectToStartOfTextToggle", // cmd-shift-left
    "\u001b[96;5u": "CommandMode", // ctrl-`
    "\u001b[109;5u": "JumpToMatchingBrace", // ctrl-m
    "\u001b[122;6u": "Redo", // ctrl-shift-z
    "Alt-/": "lua:comment.comment",
    "Alt-Delete": "SelectToEndOfLine,Delete", // cmd-delete (VS Code)
    "Alt-d": "DeleteWordRight", // opt-delete
    "Alt-g": "None",
    "Ctrl-Space": "command:palettero",
    // TODO(https://github.com/ghostty-org/ghostty/pull/2294#issue-2543878934): See if Ghostty stops translating ctrl-/ to ctrl-_
    "Ctrl-Underscore": "lua:comment.comment", // ctrl-/
    "Ctrl-a": "StartOfTextToggle", // cmd-left
    "Ctrl-e": "EndOfLine", // cmd-right
    "Ctrl-j": "None",
    "Ctrl-k": "SelectToEndOfLine,Delete", // cmd-delete
    "Ctrl-n": "None",
    "Ctrl-p": "command:palettero",
    "Ctrl-u": "SelectToStartOfLine,Backspace", // cmd-backspace
    "Ctrl-w": "DeleteWordLeft", // opt-backspace (VS Code)
    "F1": "command:palettero",
    "F3": "FindNext",
    "F4": "command:jumptag",
    "F5": "command:runit",
    "F9": "None",
    "F12": "None",
    "Shift-F3": "FindPrevious",

    "command": {
        "\u001b[96;5u": "AbortCommand" // Ctrl-`
    }
}
