IgnoreUnknown WarnWeakCrypto
Include */config

Host codeberg.org
    IdentityFile ~/.ssh/id_ecdsa_sk_rk_codeberg.pub
    StrictHostKeyChecking yes
    User git

Host github.com gist.github.com
    IdentityFile ~/.ssh/id_ecdsa_sk_rk_github.pub
    StrictHostKeyChecking yes
    User git

Host ec2
    IdentityFile ~/.ssh/id_ecdsa_sk_rk_ec2.pub
    StrictHostKeyChecking yes
    User fedora

Host ec2-*.*.compute.amazonaws.com ec2-*.compute-1.amazonaws.com
    IdentityFile ~/.ssh/id_ecdsa_sk_rk_ec2.pub
    User ec2-user
    WarnWeakCrypto no-pq-kex

Host ec2
    CanonicalizeHostname yes
    ForwardAgent yes
    HashKnownHosts yes

Host ec2
    #!! UdpMode yes
    ControlPath none  # https://github.com/trzsz/trzsz-ssh/issues/258

Host *
    ControlMaster auto
    ControlPath ~/.ssh/%r@%h:%p
    ControlPersist 10m
    ExitOnForwardFailure yes
    HostKeyAlgorithms ssh-ed25519
    SendEnv COLORTERM
    VerifyHostKeyDNS yes
