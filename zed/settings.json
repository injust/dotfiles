{
    "features": { "edit_prediction_provider": "none" },
    "buffer_font_family": "MonaspiceAr Nerd Font Propo",
    "buffer_font_features": {
        "calt": true,
        "liga": true,
        "ss01": true,
        "ss02": true,
        "ss03": true,
        "ss04": true,
        "ss05": true,
        "ss06": true,
        "ss07": true,
        "ss08": true,
        "ss09": true,
        "ss10": true,
        "cv62": true
    },
    "buffer_font_size": 13,
    "minimum_contrast_for_highlights": 0,
    "colorize_brackets": true,
    "show_signature_help_after_edits": true,
    "toolbar": { "code_actions": true },
    "title_bar": { "show_branch_icon": true, "show_sign_in": false },
    "sticky_scroll": { "enabled": true },
    "seed_search_query_from_cursor": "selection",
    "inlay_hints": { "enabled": true, "show_background": true },
    "collaboration_panel": { "button": false },
    "notification_panel": { "button": false },
    "agent": { "enabled": false },
    "autosave": { "after_delay": { "milliseconds": 500 } },
    "tabs": { "git_status": true, "file_icons": true, "show_diagnostics": "all" },
    "extend_comment_on_newline": false, // TODO(https://github.com/zed-industries/zed/discussions/24972)
    "soft_wrap": "editor_width",
    "preferred_line_length": 120,
    "telemetry": { "diagnostics": false, "metrics": false },
    "git": { "inline_blame": { "show_commit_summary": true } },
    "terminal": { "minimum_contrast": 0 },
    "auto_install_extensions": {
        "html": false // https://github.com/zed-industries/zed/pull/10867
    },
    "completions": { "words": "disabled" },
    "languages": { "Fish": { "formatter": { "external": { "command": "fish_indent" } } } }
}
