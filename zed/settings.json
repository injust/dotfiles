{
    "theme": { "light": "Catppuccin Latte", "dark": "Catppuccin Mocha" },
    "icon_theme": { "light": "Catppuccin Latte", "dark": "Catppuccin Mocha" },
    // TODO(https://github.com/zed-industries/zed/issues/15716): Use MonaspiceRn Nerd Font Propo for inlay hints
    "buffer_font_family": "MonaspiceAr Nerd Font Propo",
    "buffer_font_features": {
        "calt": true,
        "liga": true,
        "ss01": true,
        "ss02": true,
        "ss03": true,
        "ss04": true,
        "ss05": true,
        "ss06": true,
        "ss07": true,
        "ss08": true,
        "ss09": true,
        "ss10": true,
        "cv62": true // @_ ligature
    },
    "buffer_font_size": 13,
    "cli_default_open_behavior": "new_window",
    "zoomed_padding": false,
    "minimum_contrast_for_highlights": 0,
    "colorize_brackets": true,
    "completion_detail_alignment": "right",
    "show_signature_help_after_edits": true,
    "inline_code_actions": false, // https://github.com/zed-industries/zed/issues/41563
    "excerpt_context_lines": 5,
    "toolbar": { "code_actions": true },
    "title_bar": { "show_branch_status_icon": true },
    "fast_scroll_sensitivity": 1.0,
    "sticky_scroll": { "enabled": true },
    "seed_search_query_from_cursor": "selection",
    "use_smartcase_search": true,
    "inlay_hints": {
        "enabled": true,
        "show_background": true,
        "toggle_on_modifiers_press": { "control": true, "alt": true }
    },
    "project_panel": {
        "dock": "left",
        "scrollbar": { "horizontal_scroll": false },
        "diagnostic_badges": true,
        "hide_root": true
    },
    "collaboration_panel": { "button": false },
    "git_panel": { "status_style": "label_color", "file_icons": true, "tree_view": true },
    "agent": { "enabled": false },
    "document_folding_ranges": "on",
    "autosave": { "after_delay": { "milliseconds": 500 } },
    "tab_bar": { "show_pinned_tabs_in_separate_row": true },
    "tabs": { "git_status": true, "file_icons": true, "show_diagnostics": "all" },
    "file_finder": { "include_ignored": "all" },
    "extend_comment_on_newline": false, // https://github.com/zed-industries/zed/discussions/24972
    "preferred_line_length": 120,
    "telemetry": { "diagnostics": false, "metrics": false },
    // https://github.com/zed-industries/zed/discussions/46827
    "read_only_files": [
        // `detect_venv.directories`
        ".env/",
        "env/",
        ".venv/",
        "venv/",
        // basedpyright
        "~/Library/Application Support/Zed/languages/basedpyright/node_modules/basedpyright/dist/typeshed-fallback/",
        // ty
        "~/.cache/ty/vendored/typeshed/",
        // uv
        "~/.local/share/uv/python/"
    ],
    "git": { "inline_blame": { "show_commit_summary": true } },
    "edit_predictions": { "allow_data_collection": "no" },
    "terminal": {
        "blinking": "on",
        "cursor_shape": "bar",
        "env": { "GIT_EDITOR": "zed --wait" },
        "detect_venv": "off",
        "max_scroll_history_lines": 100000,
        "minimum_contrast": 0
    },
    "file_types": {
        "Ghostty": ["**/ghostty/config", "**/com.mitchellh.ghostty/config"],
        "Git Attributes": ["**/{git,.git,.git/info}/attributes"],
        "Git Config": ["*.gitconfig", "**/{git,.git/modules,.git/modules/*}/config"],
        "Git Ignore": ["**/{git,.git}/ignore", "**/.git/info/exclude"],
        "JSONC": ["*.json"],
        "Python constraints": ["*constraints*.txt"],
        "Python requirements": ["*requirements*.{in,txt}", "**/requirements/*.{in,txt}"]
    },
    "auto_install_extensions": {
        "basher": true,
        "catppuccin": true,
        "catppuccin-icons": true,
        "csv": true,
        "dependi": true,
        "fish": true,
        "ghostty": true,
        "git-firefly": true,
        "html": true, // Auto-installed by default (https://github.com/zed-industries/zed/pull/10867)
        "ini": true,
        "log": true,
        "python-requirements": true,
        "tombi": true,
        "toml": true,
        "xml": true
    },
    "completions": { "words": "disabled" },
    "languages": {
        "Fish": { "formatter": { "external": { "command": "fish_indent" } } },
        "LOG": { "show_edit_predictions": false },
        "Plain Text": { "show_edit_predictions": false, "language_servers": [] },
        "Python": { "language_servers": ["ruff", "ty"], "code_actions_on_format": { "source.fixAll.ruff": true } },
        "Shell Script": {
            "formatter": {
                "external": {
                    "command": "shfmt",
                    "arguments": ["--filename", "{buffer_path}", "--simplify", "--indent", "4"]
                }
            }
        },
        "TOML": {
            "show_edit_predictions": false // https://github.com/tombi-toml/tombi/issues/1556
        }
    },
    "lsp": {
        "basedpyright": { "settings": { "basedpyright.analysis": { "diagnosticMode": "workspace" } } },
        "gopls": { "initialization_options": { "gofumpt": true } },
        "ty": { "settings": { "diagnosticMode": "workspace" } }
    },
    "which_key": { "enabled": true, "delay_ms": 500 }
}
