[
  {
    "use_key_equivalents": true,
    "bindings": {
      "cmd-shift-c": null // TODO(https://github.com/zed-industries/zed/issues/7121)
    }
  },
  {
    "context": "Editor",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-\\": null // TODO(https://github.com/zed-industries/zed/issues/24931)
    }
  },
  {
    "context": "Workspace",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-r": null
    }
  },
  {
    "context": "Workspace && !Terminal",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-r": "projects::OpenRecent"
    }
  },
  {
    "context": "Editor && mode == full && !(ContextEditor > Editor) && extension==py || Terminal",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-r": ["task::Spawn", { "task_name": "Python: $ZED_STEM" }]
    }
  }
]
