[
    { "use_key_equivalents": true, "unbind": { "cmd-shift-c": "collab_panel::ToggleFocus" } },
    {
        "context": "Editor && mode == full && extension == py",
        "use_key_equivalents": true,
        "bindings": { "cmd-r": ["task::Spawn", { "task_name": "run module '$ZED_FILE'" }] }
    },
    {
        "context": "ProjectSearchBar",
        "use_key_equivalents": true,
        "bindings": {
            "cmd-shift-f": "pane::DeploySearch" // https://github.com/zed-industries/zed/issues/27291
        }
    },
    { "context": "Terminal", "use_key_equivalents": true, "bindings": { "cmd-r": "terminal::RerunTask" } },
    { "context": "Workspace", "use_key_equivalents": true, "unbind": { "cmd-r": "workspace::ToggleRightDock" } },
    {
        "context": "Workspace && !Terminal",
        "use_key_equivalents": true,
        "bindings": { "ctrl-r": ["projects::OpenRecent", { "create_new_window": false }] }
    }
]
