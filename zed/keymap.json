[
  {
    "context": "Editor && mode == full && inline_completion",
    "bindings": {
      // TODO(https://github.com/zed-industries/zed/issues/20167): Actually unset this so cmd-right always uses the `Editor` context keybinding
      "cmd-right": "editor::MoveToEndOfLine"
    }
  },
  {
    "context": "Editor && mode == full && !(ContextEditor > Editor) || Terminal",
    "bindings": {
      "cmd-r": ["task::Spawn", { "task_name": "Python: $ZED_STEM" }]
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-r": "projects::OpenRecent"
    }
  }
]
