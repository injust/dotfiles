[
    {
        "use_key_equivalents": true,
        "bindings": { "cmd-,": "zed::OpenSettingsFile", "cmd-alt-,": "zed::OpenDefaultSettings" },
        "unbind": { "cmd-shift-c": "collab_panel::ToggleFocus" }
    },
    {
        "context": "!ContextEditor && !AcpThread > Editor && mode == full",
        "use_key_equivalents": true,
        "unbind": {
            "ctrl-enter": "assistant::InlineAssist" // https://github.com/zed-industries/zed/discussions/50762
        }
    },
    {
        "context": "Editor",
        "use_key_equivalents": true,
        "bindings": {
            "cmd-ctrl-up": "editor::SelectLargerSyntaxNode",
            "cmd-ctrl-down": "editor::SelectSmallerSyntaxNode",
            "cmd-ctrl-left": "editor::SelectPreviousSyntaxNode",
            "cmd-ctrl-right": "editor::SelectNextSyntaxNode",
            "cmd-shift-l": "editor::SplitSelectionIntoLines"
        },
        "unbind": {
            "cmd-\\": "pane::SplitRight",
            "ctrl-shift-left": "editor::SelectSmallerSyntaxNode",
            "ctrl-shift-right": "editor::SelectLargerSyntaxNode"
        }
    },
    {
        "context": "Editor && mode == full && extension == py",
        "use_key_equivalents": true,
        "bindings": { "cmd-r": ["task::Spawn", { "task_name": "run module '$ZED_FILE'" }] }
    },
    { "context": "Pane", "use_key_equivalents": true, "bindings": { "ctrl-enter": "workspace::ToggleZoom" } },
    { "context": "Picker", "use_key_equivalents": true, "bindings": { "cmd-w": "menu::Cancel" } },
    {
        "context": "ProjectSearchBar",
        "use_key_equivalents": true,
        "bindings": {
            "cmd-shift-f": "pane::DeploySearch" // https://github.com/zed-industries/zed/issues/27291
        }
    },
    {
        "context": "Terminal",
        "use_key_equivalents": true,
        "bindings": {
            "cmd-r": "terminal::RerunTask",
            "ctrl-delete": ["terminal::SendText", "\u001b[3;5~"] // https://github.com/zed-industries/zed/issues/51725
        },
        "unbind": {
            "ctrl-enter": "assistant::InlineAssist" // https://github.com/zed-industries/zed/discussions/50762
        }
    },
    {
        "context": "Workspace",
        "use_key_equivalents": true,
        "bindings": { "cmd-9": "workspace::ActivateLastPane", "f1": "command_palette::Toggle" },
        "unbind": { "cmd-r": "workspace::ToggleRightDock" }
    },
    {
        "context": "Workspace && !Terminal",
        "use_key_equivalents": true,
        "bindings": {
            "cmd-k cmd-s": "zed::OpenKeymapFile",
            "cmd-k cmd-alt-s": "zed::OpenDefaultKeymap",
            "ctrl-r": ["projects::OpenRecent", { "create_new_window": false }]
        }
    }
]
